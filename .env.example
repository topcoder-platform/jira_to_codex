# Jira access
JIRA_BASE='https://topcoder.atlassian.net'
JIRA_EMAIL='your.name@topcoder.com'
JIRA_TOKEN='replace-with-your-jira-api-token'

# Target workspace root. This is where platform-ui, challenge-api-v6, and the
# other service repositories are checked out.
PROJECT_ROOT='/home/your-user/Documents/Git/v6'
BASE_BRANCH='develop'

# Query configuration
LIVE_JQL='project IN (PS, PM) AND issuetype IN (Task, Bug, Story, Defect, Sub-task) AND status = "To Do" AND assignee = currentUser() ORDER BY priority DESC, updated DESC'
DRY_RUN_JQL='project IN (PS, PM) AND issuetype IN (Task, Bug, Story, Defect) AND (status = "To Do" OR status = "QA Failed") AND assignee = currentUser() ORDER BY priority DESC, updated DESC'

# Runner behavior
POST_CHECK_CMD=''
STRICT_MULTILINE_FORMATTING='1'
EXTRACT_VIDEO_FRAMES='1'

# Label-to-folder hints passed into Codex.
LABEL_PATH_MAP='{"platform-ui":"platform-ui","work":"platform-ui work app","member-api":"member-api-v6","challenge-api":"challenge-api-v6","review":"platform-ui review app","review_api":"review-api-v6","community-app":"community-app","talent":"platform-ui talent-search app","wallet":"platform-ui wallet app","wallet-admin":"platform-ui wallet-admin app","projects-api":"projects-api-v6","copilot":"platform-ui copilots app","system-admin":"platform-ui system-admin app","autopilot":"autopilot-v6","account-settings":"platform-ui account-settings app","mm-api":"marathon-match-api-v6","finance":"tc-finance-api"}'
